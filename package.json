{
  "name": "essential-addons-regression",
  "version": "2.0.0",
  "description": "Visual regression testing for Essential Addons for Elementor demo pages",
  "scripts": {
    "baseline": "node capture.js --mode=baseline",
    "current": "node capture.js --mode=current",
    "compare": "node compare.js",
    "report": "node report.js",
    "test": "npm run current && npm run compare && npm run report",
    "open-report": "open reports/report.html",
    "aria:test": "playwright test",
    "aria:update": "playwright test --update-snapshots",
    "aria:desktop": "playwright test --project=desktop",
    "aria:mobile": "playwright test --project=mobile",
    "aria:report": "playwright show-report"
  },
  "dependencies": {
    "pixelmatch": "^5.3.0",
    "pngjs": "^6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "playwright-slack-report": "^1.1.110"
  }
}
